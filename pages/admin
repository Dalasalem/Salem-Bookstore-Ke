  <script src="../js/main.js"></script>
  <script>
    const ADMIN_PASSWORD = 'SalemAdmin2026';
    const storageKey = 'salemAdminLoggedIn';

    const loginForm = document.getElementById('admin-login-form');
    const passwordInput = document.getElementById('admin-password');
    const showPasswordToggle = document.getElementById('show-password');
    const adminLoginSection = document.getElementById('admin-login');
    const adminDashboard = document.getElementById('admin-dashboard');
    const logoutBtn = document.getElementById('admin-logout');
    const clearStorageBtn = document.getElementById('clear-storage');
    const storageStatus = document.getElementById('storage-status');

    function updateStorageStatus() {
      const keys = Object.keys(localStorage);
      storageStatus.textContent = keys.length
        ? `Local storage contains ${keys.length} item(s). Remove them to reset saved data.`
        : 'Local storage is empty.';
    }

    function setAdminView(loggedIn) {
      adminLoginSection.style.display = loggedIn ? 'none' : 'block';
      adminDashboard.style.display = loggedIn ? 'block' : 'none';
      updateStorageStatus();
    }

    function isLoggedIn() {
      return localStorage.getItem(storageKey) === 'true';
    }

    loginForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const value = passwordInput.value.trim();

      if (value === ADMIN_PASSWORD) {
        localStorage.setItem(storageKey, 'true');
        setAdminView(true);
      } else {
        alert('Invalid password. Please try again.');
        passwordInput.value = '';
      }
    });

    showPasswordToggle.addEventListener('change', () => {
      passwordInput.type = showPasswordToggle.checked ? 'text' : 'password';
    });

    logoutBtn.addEventListener('click', () => {
      localStorage.removeItem(storageKey);
      setAdminView(false);
    });

    clearStorageBtn.addEventListener('click', () => {
      if (!confirm('This will clear all data stored in your browser (newsletter, cart, etc.). Continue?')) {
        return;
      }
      localStorage.clear();
      updateStorageStatus();
      alert('Local storage cleared. You may need to refresh pages for changes to take effect.');
    });

    // Product management (Shop catalog stored in localStorage)
    const productForm = document.getElementById('product-form');
    const productListEl = document.getElementById('product-list');
    const productIdInput = document.getElementById('product-id');
    const productTitleInput = document.getElementById('product-title');
    const productCategoryInput = document.getElementById('product-category');
    const productDescriptionInput = document.getElementById('product-description');
    const productPriceInput = document.getElementById('product-price');
    const productIconInput = document.getElementById('product-icon');
    const productCancelBtn = document.getElementById('product-cancel');
    const resetProductsBtn = document.getElementById('reset-products');

    function resetProductForm() {
      if (!productForm) return;
      productIdInput.value = '';
      productTitleInput.value = '';
      productCategoryInput.value = '';
      productDescriptionInput.value = '';
      productPriceInput.value = '';
      productIconInput.value = '';
      productForm.querySelector('button[type="submit"]').textContent = 'Save Product';
    }

    function renderProductList() {
      if (!productListEl) return;
      const products = getProducts();
      if (products.length === 0) {
        productListEl.innerHTML = '<p style="color: var(--text-light);">No products found.</p>';
        return;
      }

      productListEl.innerHTML = '';
      products.forEach(product => {
        const item = document.createElement('div');
        item.style = 'border: 1px solid var(--border-light); border-radius: 0.5rem; padding: 0.75rem; display: flex; justify-content: space-between; align-items: center;';

        const info = document.createElement('div');
        info.innerHTML = `<strong>${product.title}</strong> <span style="color: var(--text-light);">(${product.category})</span><br><span style="color: var(--text-light);">${formatCurrency(product.price)}</span>`;

        const actions = document.createElement('div');
        actions.style.display = 'flex';
        actions.style.gap = '0.5rem';

        const editBtn = document.createElement('button');
        editBtn.type = 'button';
        editBtn.className = 'btn btn-outline';
        editBtn.textContent = 'Edit';
        editBtn.addEventListener('click', () => {
          productIdInput.value = product.id;
          productTitleInput.value = product.title;
          productCategoryInput.value = product.category;
          productDescriptionInput.value = product.description;
          productPriceInput.value = product.price;
          productIconInput.value = product.icon || '';
          if (productForm) productForm.querySelector('button[type="submit"]').textContent = 'Update Product';
          window.scrollTo({ top: productForm.getBoundingClientRect().top + window.scrollY - 80, behavior: 'smooth' });
        });

        const deleteBtn = document.createElement('button');
        deleteBtn.type = 'button';
        deleteBtn.className = 'btn btn-secondary';
        deleteBtn.textContent = 'Delete';
        deleteBtn.addEventListener('click', () => {
          if (!confirm('Delete this product?')) return;
          const updated = getProducts().filter(p => p.id !== product.id);
          saveProducts(updated);
          renderProductList();
          showToast('Product removed from catalog.', 'info');
        });

        actions.append(editBtn, deleteBtn);
        item.append(info, actions);
        productListEl.appendChild(item);
      });
    }

    if (productForm) {
      productForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const id = productIdInput.value || `product-${Date.now()}`;
        const title = productTitleInput.value.trim();
        const category = productCategoryInput.value.trim().toLowerCase();
        const description = productDescriptionInput.value.trim();
        const price = Number(productPriceInput.value);
        const icon = productIconInput.value.trim() || '📦';

        if (!title || !category || !description || !price) {
          alert('Please fill in all required fields.');
          return;
        }

        const products = getProducts();
        const existingIndex = products.findIndex(p => p.id === id);
        const updatedProduct = { id, title, category, description, price, icon };

        if (existingIndex >= 0) {
          products[existingIndex] = updatedProduct;
          showToast('Product updated.', 'success');
        } else {
          products.push(updatedProduct);
          showToast('Product added.', 'success');
        }

        saveProducts(products);
        renderProductList();
        resetProductForm();
      });

      productCancelBtn.addEventListener('click', (e) => {
        e.preventDefault();
        resetProductForm();
      });
    }

    if (resetProductsBtn) {
      resetProductsBtn.addEventListener('click', () => {
        if (!confirm('Reset the product catalog to the default set?')) return;
        localStorage.removeItem('salemProducts');
        renderProductList();
        showToast('Product catalog reset to defaults. Refresh the shop page to see changes.', 'success');
      });
    }

    function initializeProductManager() {
      renderProductList();
    }

    setAdminView(isLoggedIn());
    initializeProductManager();
  </script>
