  <!-- ========== HERO SECTION ========== -->
  <section class="hero">
    <div class="hero-content">
      <h1>Admin Panel</h1>
      <p>Secure access to manage the Salem Bookstore site (local-only admin panel).</p>
    </div>
  </section>

  <section style="padding: 3rem 2rem;">
    <div class="container">
      <div class="section-title">
        <h2>Administrator Access</h2>
      </div>

      <div id="admin-login" style="max-width: 520px; margin: 0 auto;">
        <p style="margin-bottom: 1rem;">Enter the admin password to access the dashboard. This is a local-only panel and does not connect to a backend.</p>
        <form id="admin-login-form" style="display: grid; gap: 1rem;">
          <input id="admin-password" type="password" placeholder="Admin password" required style="padding: 0.75rem; border: 1px solid var(--border-light); border-radius: 0.5rem; font-size: 1rem;">
          <div style="display: flex; gap: 0.5rem; align-items: center;">
            <input id="show-password" type="checkbox" style="width: auto;" />
            <label for="show-password" style="font-size: 0.95rem; color: var(--text-light);">Show password</label>
          </div>
          <button type="submit" class="btn btn-primary">Sign In</button>
        </form>
      </div>

      <div id="admin-dashboard" style="display: none; margin-top: 2rem;">
        <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; align-items: center;">
          <div>
            <h3>Dashboard</h3>
            <p>Manage data stored in your browser and quickly access site tools.</p>
          </div>
          <button id="admin-logout" class="btn btn-secondary">Logout</button>
        </div>

        <div style="margin-top: 2rem; display: grid; gap: 1.5rem;">
          <div style="border: 1px solid var(--border-light); border-radius: 0.75rem; padding: 1.5rem; background: var(--white);">
            <h4>Local Storage Status</h4>
            <p id="storage-status" style="margin-bottom: 1rem; color: var(--text-light);"></p>
            <button id="clear-storage" class="btn btn-outline" style="width: 100%;">Clear Local Data</button>
          </div>

          <div style="border: 1px solid var(--border-light); border-radius: 0.75rem; padding: 1.5rem; background: var(--white);">
            <h4>Quick Links</h4>
            <ul style="list-style: none; padding: 0; margin: 0;">
              <li><a href="shop.html" class="btn btn-outline" style="display: inline-block; width: 100%; text-align: left;">Open Shop Page</a></li>
              <li><a href="../index.html" class="btn btn-outline" style="display: inline-block; width: 100%; text-align: left; margin-top: 0.5rem;">Open Home Page</a></li>
            </ul>
          </div>
        </div>

        <div style="margin-top: 2rem; border: 1px solid var(--border-light); border-radius: 0.75rem; padding: 1.5rem; background: var(--white);">
          <h4>Notes</h4>
          <p style="margin-bottom: 0.5rem;">This admin panel is a safe, browser-only tool. It does not store or send any data externally.</p>
          <p style="margin-bottom: 0;">Use <strong>Clear Local Data</strong> to reset any saved values (newsletter subscription, cart, etc.) in this browser.</p>
        </div>

        <div id="product-manager" style="margin-top: 2rem; border: 1px solid var(--border-light); border-radius: 0.75rem; padding: 1.5rem; background: var(--white);">
          <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem;">
            <div>
              <h4 style="margin: 0;">Product Catalog (Shop)</h4>
              <p style="margin: 0.5rem 0 1rem;">Edit the product list shown on the Shop page. Changes are stored in your browser.</p>
            </div>
            <button id="add-product" class="btn btn-primary" style="flex-shrink: 0;">Add Product</button>
          </div>

          <div style="display: grid; gap: 1.25rem;">
            <form id="product-form" style="display: grid; gap: 0.75rem;">
              <input type="hidden" id="product-id">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
                <input id="product-title" type="text" placeholder="Title" required style="padding: 0.75rem; border: 1px solid var(--border-light); border-radius: 0.5rem;">
                <input id="product-category" type="text" placeholder="Category (e.g. bibles)" required style="padding: 0.75rem; border: 1px solid var(--border-light); border-radius: 0.5rem;">
              </div>
              <textarea id="product-description" placeholder="Description" rows="2" required style="padding: 0.75rem; border: 1px solid var(--border-light); border-radius: 0.5rem;"></textarea>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
                <input id="product-price" type="number" min="0" placeholder="Price (KES)" required style="padding: 0.75rem; border: 1px solid var(--border-light); border-radius: 0.5rem;">
                <input id="product-icon" type="text" placeholder="Icon (emoji)" style="padding: 0.75rem; border: 1px solid var(--border-light); border-radius: 0.5rem;">
              </div>
              <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <button type="submit" class="btn btn-primary">Save Product</button>
                <button type="button" id="product-cancel" class="btn btn-secondary">Cancel</button>
                <button type="button" id="reset-products" class="btn btn-outline" style="margin-left: auto;">Reset To Defaults</button>
              </div>
            </form>

            <div>
              <h5 style="margin-bottom: 0.5rem;">Product List</h5>
              <div id="product-list" style="display: grid; gap: 0.75rem;"></div>
            </div>
          </div>
        </div>

        <div id="orders-manager" style="margin-top: 2rem; border: 1px solid var(--border-light); border-radius: 0.75rem; padding: 1.5rem; background: var(--white);">
          <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem;">
            <div>
              <h4 style="margin: 0;">Orders</h4>
              <p style="margin: 0.5rem 0 1rem;">Orders placed from the Shop page (stored locally).</p>
            </div>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
              <button id="refresh-orders" class="btn btn-outline">Refresh</button>
              <button id="clear-orders" class="btn btn-secondary">Clear Orders</button>
            </div>
          </div>
          <div id="orders-list" style="display: grid; gap: 0.75rem;"></div>
        </div>

        <div id="messages-manager" style="margin-top: 2rem; border: 1px solid var(--border-light); border-radius: 0.75rem; padding: 1.5rem; background: var(--white);">
          <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem;">
            <div>
              <h4 style="margin: 0;">Messages</h4>
              <p style="margin: 0.5rem 0 1rem;">Messages submitted via Contact form or WhatsApp (stored locally).</p>
            </div>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
              <button id="refresh-messages" class="btn btn-outline">Refresh</button>
              <button id="clear-messages" class="btn btn-secondary">Clear Messages</button>
            </div>
          </div>
          <div id="messages-list" style="display: grid; gap: 0.75rem;"></div>
        </div>
      </div>
    </div>
  </section>

